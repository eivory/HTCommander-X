<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.RadioChannelDialog"
        Title="Channel Editor"
        Width="460" Height="480"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Name="AdvancedButton" Content="Advanced" Click="AdvancedButton_Click"
                    Padding="12,6" />
            <Button Name="OkButton" Content="OK" Click="OkButton_Click" Padding="16,6" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>

        <ScrollViewer>
            <StackPanel Spacing="8">
                <TextBlock Text="Basic Settings" FontWeight="SemiBold" FontSize="14" />

                <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,4,0,0">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Channel:" VerticalAlignment="Center" />
                    <TextBlock Name="ChannelIdText" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Frequency (MHz):" VerticalAlignment="Center" Margin="0,6,0,0" />
                    <TextBox Name="FrequencyBox" Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,6,0,0" />
                    <TextBox Name="ChannelNameBox" Grid.Row="2" Grid.Column="1" MaxLength="10" Margin="0,6,0,0" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Mode:" VerticalAlignment="Center" Margin="0,6,0,0" />
                    <ComboBox Name="ModeCombo" Grid.Row="3" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,6,0,0">
                        <ComboBoxItem Content="FM" />
                        <ComboBoxItem Content="AM" />
                        <ComboBoxItem Content="DMR" />
                    </ComboBox>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Bandwidth:" VerticalAlignment="Center" Margin="0,6,0,0" />
                    <ComboBox Name="BandwidthCombo" Grid.Row="4" Grid.Column="1" Width="160" HorizontalAlignment="Left" Margin="0,6,0,0">
                        <ComboBoxItem Content="Narrow (12.5kHz)" />
                        <ComboBoxItem Content="Wide (25kHz)" />
                    </ComboBox>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Power:" VerticalAlignment="Center" Margin="0,6,0,0" />
                    <ComboBox Name="PowerCombo" Grid.Row="5" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,6,0,0">
                        <ComboBoxItem Content="Low" />
                        <ComboBoxItem Content="Medium" />
                        <ComboBoxItem Content="High" />
                    </ComboBox>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="TX CTCSS/DCS:" VerticalAlignment="Center" Margin="0,6,0,0" />
                    <ComboBox Name="TxToneCombo" Grid.Row="6" Grid.Column="1" Width="160" HorizontalAlignment="Left" Margin="0,6,0,0" />

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="RX CTCSS/DCS:" VerticalAlignment="Center" Margin="0,6,0,0" />
                    <ComboBox Name="RxToneCombo" Grid.Row="7" Grid.Column="1" Width="160" HorizontalAlignment="Left" Margin="0,6,0,0" />
                </Grid>

                <StackPanel Margin="0,8,0,0" Spacing="4">
                    <CheckBox Name="MuteCheck" Content="Mute" />
                    <CheckBox Name="DisableTransmitCheck" Content="Disable Transmit" />
                    <CheckBox Name="ScanCheck" Content="Include in Scan" />
                </StackPanel>

                <!-- Advanced fields (hidden by default) -->
                <StackPanel Name="AdvancedPanel" IsVisible="False" Spacing="8" Margin="0,12,0,0">
                    <TextBlock Text="Advanced Settings" FontWeight="SemiBold" FontSize="14" />

                    <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto" Margin="0,4,0,0">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="TX Freq (MHz):" VerticalAlignment="Center" />
                        <TextBox Name="TxFrequencyBox" Grid.Row="0" Grid.Column="1" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="RX Freq (MHz):" VerticalAlignment="Center" Margin="0,6,0,0" />
                        <TextBox Name="RxFrequencyBox" Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" />
                    </Grid>

                    <StackPanel Spacing="4">
                        <CheckBox Name="TalkAroundCheck" Content="Talk Around" />
                        <CheckBox Name="DeemphasisCheck" Content="De-emphasis Bypass" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
