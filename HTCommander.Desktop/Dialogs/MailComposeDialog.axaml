<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.MailComposeDialog"
        Title="Compose Mail"
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Send" Click="SendButton_Click" Padding="16,6" />
            <Button Content="Save Draft" Click="SaveDraftButton_Click" Padding="12,6" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,8">
            <Grid ColumnDefinitions="60,*">
                <TextBlock Text="To:" VerticalAlignment="Center" />
                <TextBox Name="ToBox" Grid.Column="1" Watermark="Callsign or email" />
            </Grid>
            <Grid ColumnDefinitions="60,*">
                <TextBlock Text="Cc:" VerticalAlignment="Center" />
                <TextBox Name="CcBox" Grid.Column="1" Watermark="Optional" />
            </Grid>
            <Grid ColumnDefinitions="60,*">
                <TextBlock Text="Subject:" VerticalAlignment="Center" />
                <TextBox Name="SubjectBox" Grid.Column="1" />
            </Grid>
        </StackPanel>

        <TextBox Name="BodyBox" AcceptsReturn="True" TextWrapping="Wrap"
                 Watermark="Type your message here..."
                 Background="#1E1E1E" Foreground="#D4D4D4" />
    </DockPanel>
</Window>
