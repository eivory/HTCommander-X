<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.SettingsDialog"
        Title="Settings"
        Width="620" Height="580"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <DockPanel Margin="12">
        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Name="OkButton" Content="OK" Click="OkButton_Click" Padding="20,6" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="20,6" />
        </StackPanel>

        <TabControl>
            <!-- General tab (was License) -->
            <TabItem Header="General">
                <StackPanel Spacing="12" Margin="12">
                    <TextBlock Text="An Amateur radio license is required to transmit."
                               Foreground="#888" FontSize="12" TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="110,*" Margin="0,0,0,0">
                        <TextBlock Grid.Column="0" Text="Theme:" VerticalAlignment="Center" />
                        <ComboBox Name="ThemeCombo" Grid.Column="1" Width="160" HorizontalAlignment="Left">
                            <ComboBoxItem Content="Auto (System)" Tag="Auto" />
                            <ComboBoxItem Content="Light" Tag="Light" />
                            <ComboBoxItem Content="Dark" Tag="Dark" />
                        </ComboBox>
                    </Grid>
                    <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto" Margin="0,8,0,0">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Call Sign:" VerticalAlignment="Center" />
                        <TextBox Name="CallSignBox" Grid.Row="0" Grid.Column="1" Width="140"
                                 MaxLength="6" HorizontalAlignment="Left"
                                 TextChanged="CallSignBox_TextChanged" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Station ID:" VerticalAlignment="Center" Margin="0,8,0,0" />
                        <ComboBox Name="StationIdCombo" Grid.Row="1" Grid.Column="1" Width="80"
                                  HorizontalAlignment="Left" Margin="0,8,0,0" />
                    </Grid>
                    <CheckBox Name="AllowTransmitCheck" Content="Allow Transmit" Margin="0,8,0,0" IsEnabled="False" />
                    <TextBlock Name="TransmitWarning" Text="Enter a valid call sign (3+ characters) to enable transmit."
                               Foreground="#F44336" FontSize="11" Margin="24,0,0,0" />
                    <CheckBox Name="CheckUpdatesCheck" Content="Check for updates on startup" Margin="0,4,0,0" />
                    <Button Name="ResetDefaultsButton" Content="Reset All Settings to Defaults"
                            Click="ResetDefaults_Click" Padding="12,6" Margin="0,12,0,0"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </TabItem>

            <!-- APRS tab -->
            <TabItem Header="APRS">
                <DockPanel Margin="12">
                    <TextBlock DockPanel.Dock="Top" Text="APRS Routes" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="4" Margin="0,8,0,0">
                        <Button Content="Add" Click="AddRoute_Click" Padding="12,4" />
                        <Button Name="EditRouteBtn" Content="Edit" Click="EditRoute_Click" Padding="12,4" IsEnabled="False" />
                        <Button Name="DeleteRouteBtn" Content="Delete" Click="DeleteRoute_Click" Padding="12,4" IsEnabled="False" />
                    </StackPanel>
                    <DataGrid Name="AprsRoutesGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" SelectionChanged="AprsRoutesGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Width="150" Binding="{Binding Name}" />
                            <DataGridTextColumn Header="Route" Width="*" Binding="{Binding Route}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Voice tab -->
            <TabItem Header="Voice">
                <StackPanel Spacing="12" Margin="12">
                    <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Language:" VerticalAlignment="Center" />
                        <ComboBox Name="VoiceLanguageCombo" Grid.Row="0" Grid.Column="1" Width="220" HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="TTS Voice:" VerticalAlignment="Center" Margin="0,8,0,0" />
                        <ComboBox Name="VoiceCombo" Grid.Row="1" Grid.Column="1" Width="280" HorizontalAlignment="Left" Margin="0,8,0,0" />
                    </Grid>
                    <CheckBox Name="SpeechToTextCheck" Content="Enable Speech-to-Text (Whisper)" Margin="0,4,0,0" />
                </StackPanel>
            </TabItem>

            <!-- Winlink tab -->
            <TabItem Header="Winlink">
                <StackPanel Spacing="12" Margin="12">
                    <Grid ColumnDefinitions="110,*" RowDefinitions="Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Password:" VerticalAlignment="Center" />
                        <TextBox Name="WinlinkPasswordBox" Grid.Row="0" Grid.Column="1" Width="220"
                                 PasswordChar="●" MaxLength="128" HorizontalAlignment="Left" />
                    </Grid>
                    <CheckBox Name="WinlinkUseStationIdCheck" Content="Use Station ID in Winlink address" />
                </StackPanel>
            </TabItem>

            <!-- Servers tab -->
            <TabItem Header="Servers">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16" Margin="12">
                    <CheckBox Name="ServerBindAllCheck" Content="Allow remote access (bind to all network interfaces)" />
                    <StackPanel Spacing="4">
                        <CheckBox Name="TlsEnabledCheck" Content="Enable TLS/HTTPS (required for mobile microphone over LAN)" />
                        <TextBlock Text="Generates a self-signed certificate. Accept the browser security warning on first connect."
                                   Foreground="{DynamicResource SecondaryText}" FontSize="11" Margin="24,0,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <CheckBox Name="WebServerCheck" Content="Enable Web Server" />
                        <Grid ColumnDefinitions="110,*" Margin="24,0,0,0">
                            <TextBlock Grid.Column="0" Text="Port:" VerticalAlignment="Center" />
                            <NumericUpDown Name="WebPortUpDown" Grid.Column="1" Width="120"
                                           Minimum="1" Maximum="65535" Value="8080" HorizontalAlignment="Left" />
                        </Grid>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <CheckBox Name="AgwpeServerCheck" Content="Enable AGWPE Server" />
                        <Grid ColumnDefinitions="110,*" Margin="24,0,0,0">
                            <TextBlock Grid.Column="0" Text="Port:" VerticalAlignment="Center" />
                            <NumericUpDown Name="AgwpePortUpDown" Grid.Column="1" Width="120"
                                           Minimum="1" Maximum="65535" Value="8000" HorizontalAlignment="Left" />
                        </Grid>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <CheckBox Name="RigctldServerCheck" Content="Enable Rigctld Server (Hamlib)" />
                        <Grid ColumnDefinitions="110,*" Margin="24,0,0,0">
                            <TextBlock Grid.Column="0" Text="Port:" VerticalAlignment="Center" />
                            <NumericUpDown Name="RigctldPortUpDown" Grid.Column="1" Width="120"
                                           Minimum="1" Maximum="65535" Value="4532" HorizontalAlignment="Left" />
                        </Grid>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <CheckBox Name="CatServerCheck" Content="Enable CAT Server (Kenwood TS-2000)" />
                        <Grid Name="CatComPortPanel" ColumnDefinitions="Auto,Auto" Margin="24,0,0,0" IsVisible="False">
                            <TextBlock Grid.Column="0" Text="COM Port:" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox Name="CatComPortCombo" Grid.Column="1" Width="120" />
                        </Grid>
                        <TextBlock Name="CatPortLabel" Text="" Foreground="{DynamicResource SecondaryText}" FontSize="11" Margin="24,0,0,0" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <CheckBox Name="VirtualAudioCheck" Content="Enable Virtual Audio Bridge" />
                        <TextBlock Text="Creates virtual audio devices for external software (requires PulseAudio/PipeWire)."
                                   Foreground="{DynamicResource SecondaryText}" FontSize="11" Margin="24,0,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <CheckBox Name="McpServerCheck" Content="Enable MCP Server (AI Control)" />
                        <Grid ColumnDefinitions="110,*" Margin="24,0,0,0">
                            <TextBlock Grid.Column="0" Text="Port:" VerticalAlignment="Center" />
                            <NumericUpDown Name="McpPortUpDown" Grid.Column="1" Width="120"
                                           Minimum="1" Maximum="65535" Value="5678" HorizontalAlignment="Left" />
                        </Grid>
                        <CheckBox Name="McpDebugCheck" Content="Enable debug tools (DataBroker inspection, event dispatch)"
                                  Margin="24,0,0,0" />
                        <TextBlock Text="Exposes radio control and state via Model Context Protocol for AI assistants (Claude Code, etc.)."
                                   Foreground="{DynamicResource SecondaryText}" FontSize="11" Margin="24,0,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock Name="PortWarning" Text="" Foreground="#F44336" FontSize="11" />
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Data Sources tab -->
            <TabItem Header="Data Sources">
                <StackPanel Spacing="16" Margin="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Airplane Tracking (Dump1090)" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="110,*,Auto" Margin="0,4,0,0">
                            <TextBlock Grid.Column="0" Text="Server URL:" VerticalAlignment="Center" />
                            <TextBox Name="AirplaneServerBox" Grid.Column="1"
                                     Watermark="http://localhost:8080/data/aircraft.json" />
                            <Button Grid.Column="2" Content="Test" Click="TestAirplaneServer_Click"
                                    Padding="12,4" Margin="4,0,0,0" />
                        </Grid>
                        <TextBlock Name="AirplaneTestResult" Text="" FontSize="11" Margin="110,0,0,0" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="GPS Serial Port" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto" Margin="0,4,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Serial Port:" VerticalAlignment="Center" />
                            <ComboBox Name="GpsPortCombo" Grid.Row="0" Grid.Column="1" Width="180" HorizontalAlignment="Left" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Baud Rate:" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <ComboBox Name="GpsBaudCombo" Grid.Row="1" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0">
                                <ComboBoxItem Content="4800" Tag="4800" />
                                <ComboBoxItem Content="9600" Tag="9600" />
                                <ComboBoxItem Content="19200" Tag="19200" />
                                <ComboBoxItem Content="38400" Tag="38400" />
                                <ComboBoxItem Content="57600" Tag="57600" />
                                <ComboBoxItem Content="115200" Tag="115200" />
                            </ComboBox>
                        </Grid>
                        <TextBlock Name="GpsStatusLabel" Text="" FontSize="11" Margin="110,4,0,0" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="RepeaterBook Defaults" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto" Margin="0,4,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Country:" VerticalAlignment="Center" />
                            <ComboBox Name="RBCountryCombo" Grid.Row="0" Grid.Column="1" Width="200" HorizontalAlignment="Left"
                                      SelectionChanged="RBCountryCombo_SelectionChanged" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="State:" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <ComboBox Name="RBStateCombo" Grid.Row="1" Grid.Column="1" Width="200" HorizontalAlignment="Left" Margin="0,8,0,0" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Audio tab (now includes controls from RadioAudioDialog) -->
            <TabItem Header="Audio">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12" Margin="12">
                    <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Output Device:" VerticalAlignment="Center" />
                        <ComboBox Name="OutputDeviceCombo" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Input Device:" VerticalAlignment="Center" Margin="0,8,0,0" />
                        <ComboBox Name="InputDeviceCombo" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                    </Grid>

                    <!-- Radio Volume (hardware 0-15) -->
                    <StackPanel Spacing="4" Margin="0,8,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Radio Volume" FontWeight="SemiBold" />
                            <TextBlock Name="VolumeValueText" Grid.Column="1" Text="0" Foreground="{DynamicResource SecondaryText}" />
                        </Grid>
                        <Slider Name="VolumeSlider" Minimum="0" Maximum="15"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="VolumeSlider_Changed" />
                    </StackPanel>

                    <!-- Squelch (0-9) -->
                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Squelch Level" FontWeight="SemiBold" />
                            <TextBlock Name="SquelchValueText" Grid.Column="1" Text="0" Foreground="{DynamicResource SecondaryText}" />
                        </Grid>
                        <Slider Name="SquelchSlider" Minimum="0" Maximum="9"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="SquelchSlider_Changed" />
                    </StackPanel>

                    <!-- Software Output Volume (0-100) -->
                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Output Volume" FontWeight="SemiBold" />
                            <TextBlock Name="OutputVolumeText" Grid.Column="1" Text="100%" Foreground="{DynamicResource SecondaryText}" />
                        </Grid>
                        <Slider Name="OutputVolumeSlider" Minimum="0" Maximum="100"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="OutputVolumeSlider_Changed" />
                        <CheckBox Name="MuteCheck" Content="Mute" Click="Mute_Click" />
                    </StackPanel>

                    <!-- Mic Gain -->
                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Mic Gain" FontWeight="SemiBold" />
                            <TextBlock Name="MicGainText" Grid.Column="1" Text="100%" Foreground="{DynamicResource SecondaryText}" />
                        </Grid>
                        <Slider Name="MicGainSlider" Minimum="0" Maximum="200"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Value="100"
                                ValueChanged="MicGainSlider_Changed" />
                        <TextBlock Text="0% = mute, 100% = normal, 200% = 2x boost" Foreground="{DynamicResource TertiaryText}" FontSize="10" />
                    </StackPanel>

                    <TextBlock Name="AudioControlsNote" Text="Connect a radio to adjust volume and squelch."
                               Foreground="{DynamicResource SecondaryText}" FontSize="11" FontStyle="Italic" />
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Modem tab -->
            <TabItem Header="Modem">
                <StackPanel Spacing="12" Margin="12">
                    <Grid ColumnDefinitions="110,*">
                        <TextBlock Grid.Column="0" Text="Modem Mode:" VerticalAlignment="Center" />
                        <ComboBox Name="ModemModeCombo" Grid.Column="1" Width="180" HorizontalAlignment="Left">
                            <ComboBoxItem Content="None" Tag="None" />
                            <ComboBoxItem Content="AFSK 1200" Tag="AFSK1200" />
                            <ComboBoxItem Content="PSK 2400" Tag="PSK2400" />
                            <ComboBoxItem Content="PSK 4800" Tag="PSK4800" />
                            <ComboBoxItem Content="G3RUH 9600" Tag="G3RUH9600" />
                        </ComboBox>
                    </Grid>
                    <TextBlock Text="The software modem decodes digital signals from the radio audio stream. Enable audio streaming (Radio menu) for the modem to function."
                               Foreground="{DynamicResource SecondaryText}" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
