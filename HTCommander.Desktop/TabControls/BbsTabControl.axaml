<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HTCommander.Desktop.TabControls.BbsTabControl">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2D2D30" Height="46" Padding="10,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="BBS" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Name="BbsStatus" Text="Inactive"
                               VerticalAlignment="Center" Foreground="#888" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="4">
                    <CheckBox Name="ViewTrafficCheck" Content="View Traffic"
                              IsChecked="True" Click="ViewTraffic_Click" />
                    <Button Name="ActivateButton" Content="Activate"
                            Click="ActivateButton_Click" Padding="8,2" IsEnabled="False" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="150" />
            </Grid.RowDefinitions>

            <DataGrid Name="BbsGrid" Grid.Row="0" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Call Sign" Width="120" Binding="{Binding Callsign}" />
                    <DataGridTextColumn Header="Last Seen" Width="150" Binding="{Binding LastSeenStr}" />
                    <DataGridTextColumn Header="Packets In" Width="80" Binding="{Binding TotalPacketsIn}" />
                    <DataGridTextColumn Header="Packets Out" Width="80" Binding="{Binding TotalPacketsOut}" />
                    <DataGridTextColumn Header="Bytes In" Width="80" Binding="{Binding TotalBytesIn}" />
                    <DataGridTextColumn Header="Bytes Out" Width="80" Binding="{Binding TotalBytesOut}" />
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                          Background="#444" />

            <TextBox Name="TrafficLog" Grid.Row="2" IsReadOnly="True"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     FontFamily="Consolas,Courier New,monospace" FontSize="11"
                     Background="#1E1E1E" Foreground="#D4D4D4" />
        </Grid>
    </DockPanel>
</UserControl>
