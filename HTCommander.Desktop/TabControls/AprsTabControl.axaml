<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HTCommander.Desktop.TabControls.AprsTabControl">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2D2D30" Height="46" Padding="10,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="APRS" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Name="CallSignLabel" Text="" FontWeight="Bold"
                               Foreground="#4FC3F7" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="4">
                    <CheckBox Name="ShowTelemetryCheck" Content="Show All"
                              Click="ShowTelemetry_Click" />
                    <TextBlock Name="MessageCount" Text="0 messages"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Missing APRS channel warning -->
        <Border Name="MissingChannelPanel" DockPanel.Dock="Top" Background="#3E2723"
                Padding="8,4" IsVisible="False">
            <TextBlock Text="No APRS channel found on connected radio. Create a channel named 'APRS' to enable APRS messaging."
                       Foreground="#FFAB91" TextWrapping="Wrap" FontSize="11" />
        </Border>

        <!-- Transmit bar at bottom -->
        <Grid DockPanel.Dock="Bottom" Height="40" Margin="4"
              Name="TransmitPanel" IsVisible="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox Name="RouteCombo" Grid.Column="0" Width="120" Margin="0,0,4,0" />
            <AutoCompleteBox Name="DestCombo" Grid.Column="1" Width="140" Margin="0,0,4,0"
                               Watermark="Destination" FilterMode="StartsWith" />
            <TextBox Name="AprsMessageBox" Grid.Column="2" Watermark="APRS message..."
                     KeyDown="AprsMessageBox_KeyDown" />
            <Button Name="SendAprsButton" Grid.Column="3" Content="Send"
                    Click="SendAprsButton_Click" Padding="12,2" Margin="4,0,0,0" IsEnabled="False" />
        </Grid>

        <!-- Message list -->
        <DataGrid Name="AprsGrid" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Width="80" Binding="{Binding Time}" />
                <DataGridTextColumn Header="From" Width="100" Binding="{Binding From}" />
                <DataGridTextColumn Header="To" Width="120" Binding="{Binding To}" />
                <DataGridTextColumn Header="Type" Width="70" Binding="{Binding Type}" />
                <DataGridTextColumn Header="Message" Width="*" Binding="{Binding Message}" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
