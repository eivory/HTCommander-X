<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HTCommander.Desktop.TabControls.TerminalTabControl">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2D2D30" Height="46" Padding="10,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="Terminal" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Name="ConnectionStatus" Text="Disconnected"
                               VerticalAlignment="Center" Foreground="#888" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="4">
                    <ComboBox Name="StationCombo" Width="140" />
                    <Button Name="ConnectButton" Content="Connect"
                            Click="ConnectButton_Click" Padding="8,2" IsEnabled="False" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Input area at bottom -->
        <Grid DockPanel.Dock="Bottom" Height="36" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Name="InputBox" Grid.Column="0" Watermark="Type message..."
                     KeyDown="InputBox_KeyDown" IsEnabled="False" />
            <Button Name="SendButton" Grid.Column="1" Content="Send"
                    Click="SendButton_Click" Padding="12,2" Margin="4,0,0,0"
                    IsEnabled="False" />
        </Grid>

        <!-- Terminal output -->
        <TextBox Name="TerminalOutput" IsReadOnly="True" AcceptsReturn="True"
                 TextWrapping="Wrap" FontFamily="Consolas,Courier New,monospace"
                 FontSize="12" Background="#1E1E1E" Foreground="#D4D4D4" />
    </DockPanel>
</UserControl>
