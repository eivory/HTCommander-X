<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tabs="clr-namespace:HTCommander.Desktop.TabControls"
        x:Class="HTCommander.Desktop.MainWindow"
        Title="HTCommander"
        Width="1200" Height="800"
        MinWidth="600" MinHeight="400">
    <Window.Styles>
        <Style Selector="Border.vfoCard:pointerover">
            <Setter Property="Opacity" Value="0.85" />
        </Style>
    </Window.Styles>
    <DockPanel>
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Name="MenuConnect" Header="_Connect..." Click="ConnectButton_Click" />
                <MenuItem Name="MenuDisconnect" Header="_Disconnect" Click="DisconnectButton_Click" IsEnabled="False" />
                <Separator />
                <MenuItem Name="MenuSettings" Header="_Settings..." Click="MenuSettings_Click" />
                <Separator />
                <MenuItem Header="E_xit" Click="MenuExit_Click" />
            </MenuItem>
            <MenuItem Header="_Radio">
                <MenuItem Name="MenuDualWatch" Header="_Dual Watch" Click="MenuDualWatch_Click" IsEnabled="False">
                    <MenuItem.Icon>
                        <CheckBox Name="DualWatchCheck" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Name="MenuScan" Header="_Scan" Click="MenuScan_Click" IsEnabled="False">
                    <MenuItem.Icon>
                        <CheckBox Name="ScanCheck" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Name="MenuGpsEnabled" Header="_GPS Enabled" Click="MenuGpsEnabled_Click" IsEnabled="False">
                    <MenuItem.Icon>
                        <CheckBox Name="GpsEnabledCheck" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Name="MenuAudioEnabled" Header="_Audio Enabled" Click="MenuAudioEnabled_Click" IsEnabled="False">
                    <MenuItem.Icon>
                        <CheckBox Name="AudioEnabledCheck" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Name="MenuSoftwareModem" Header="Software _Modem" Click="MenuSoftwareModem_Click">
                    <MenuItem.Icon>
                        <CheckBox Name="SoftwareModemCheck" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Name="MenuExportChannels" Header="_Export Channels..." Click="MenuExportChannels_Click" IsEnabled="False" />
                <MenuItem Name="MenuImportChannels" Header="_Import Channels..." Click="MenuImportChannels_Click" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Name="MenuRadioPanel" Header="_Radio Panel" Click="MenuRadioPanel_Click">
                    <MenuItem.Icon>
                        <CheckBox Name="RadioPanelCheck" IsChecked="True" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Name="MenuAllChannels" Header="_All Channels" Click="MenuAllChannels_Click">
                    <MenuItem.Icon>
                        <CheckBox Name="AllChannelsCheck" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Name="MenuRadioSelect" Header="Active _Radio" IsVisible="False" />
                <Separator />
                <MenuItem Name="MenuSpectrogram" Header="S_pectrogram..." Click="MenuSpectrogram_Click" />
                <MenuItem Name="MenuAudioClips" Header="Audio _Clips..." Click="MenuAudioClips_Click" IsEnabled="False" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Name="MenuRadioInfo" Header="Radio _Information..." Click="MenuRadioInfo_Click" IsEnabled="False" />
                <MenuItem Name="MenuGpsInfo" Header="_GPS Information..." Click="MenuGpsInfo_Click" IsEnabled="False" />
                <Separator />
                <MenuItem Name="MenuCheckUpdates" Header="Check for _Updates..." Click="MenuCheckUpdates_Click" />
                <Separator />
                <MenuItem Header="_About HTCommander..." Click="MenuAbout_Click" />
            </MenuItem>
        </Menu>

        <!-- Top toolbar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource TabHeaderBackground}" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Name="ConnectButton" Content="Connect Radio" Click="ConnectButton_Click" />
                <Button Name="DisconnectButton" Content="Disconnect" Click="DisconnectButton_Click" IsEnabled="False" />
                <TextBlock Name="StatusText" VerticalAlignment="Center" Text="Not connected" Margin="16,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#007ACC" Padding="8,3">
            <Grid>
                <TextBlock Name="StatusBarText" Text="Ready" Foreground="White" FontSize="12" />
                <TextBlock Name="BatteryStatusText" Text="" Foreground="White" FontSize="12"
                           HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- Left radio info panel -->
        <Border Name="RadioPanel" DockPanel.Dock="Left" Width="300" IsVisible="False"
                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,0,1,0" Background="{DynamicResource PanelBackground}">
            <ScrollViewer>
                <StackPanel>
                    <!-- Radio image with overlaid display -->
                    <Grid HorizontalAlignment="Center" Margin="0,8,0,0">
                        <Image Source="avares://HTCommander.Desktop/Assets/images/Radio.png"
                               Width="220" Stretch="Uniform" />
                        <!-- Overlay: radio screen display area -->
                        <Border Background="#1A2332" CornerRadius="2" Opacity="0.92"
                                Width="137" Height="117" ClipToBounds="True"
                                HorizontalAlignment="Center" VerticalAlignment="Top"
                                Margin="6,118,0,0">
                            <StackPanel Margin="4,2">
                                <!-- Radio name -->
                                <TextBlock Name="RadioNameText" Text="VR-N76" FontSize="12"
                                           Foreground="#80CBC4" HorizontalAlignment="Center"
                                           FontFamily="Consolas,Liberation Mono,monospace" />
                                <!-- State -->
                                <TextBlock Name="RadioStateText" Text="Disconnected" FontSize="10"
                                           Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,1" />
                                <!-- VFO A freq on screen -->
                                <TextBlock Name="ScreenVfoA" Text="----.---"
                                           FontSize="20" Foreground="#4FC3F7" FontWeight="Bold"
                                           FontFamily="Consolas,Liberation Mono,monospace"
                                           HorizontalAlignment="Center" />
                                <!-- VFO B freq on screen -->
                                <TextBlock Name="ScreenVfoB" Text="----.---"
                                           FontSize="15" Foreground="#81C784"
                                           FontFamily="Consolas,Liberation Mono,monospace"
                                           HorizontalAlignment="Center" />
                                <!-- Signal dots instead of progress bar -->
                                <TextBlock Name="ScreenRssiText" Text="S ▮▮▮▯▯▯▯▯"
                                           FontSize="10" Foreground="#4FC3F7"
                                           FontFamily="Consolas,Liberation Mono,monospace"
                                           HorizontalAlignment="Center" Margin="0,1,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- PTT button under radio image -->
                    <Border Name="MainPttButton" Margin="12,8,12,0" Height="40" CornerRadius="4"
                            Background="#444" Cursor="Hand" IsVisible="False"
                            PointerPressed="MainPttButton_PointerPressed"
                            PointerReleased="MainPttButton_PointerReleased">
                        <TextBlock Name="MainPttText" Text="Push to Talk" FontSize="14" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <!-- WAV transmit buttons -->
                    <Grid Name="WavTransmitPanel" Margin="12,4,12,0" ColumnDefinitions="*,*" IsVisible="False">
                        <Button Name="MainSelectWavButton" Grid.Column="0" Content="Select WAV..."
                                Click="MainSelectWav_Click" Padding="4,4" Margin="0,0,2,0"
                                HorizontalAlignment="Stretch" FontSize="11" />
                        <Button Name="MainTransmitWavButton" Grid.Column="1" Content="Transmit File"
                                Click="MainTransmitWav_Click" Padding="4,4" Margin="2,0,0,0"
                                HorizontalAlignment="Stretch" FontSize="11" IsEnabled="False" />
                    </Grid>
                    <TextBlock Name="MainWavStatus" Text="" Foreground="{DynamicResource SecondaryText}" FontSize="10"
                               Margin="12,2,12,0" HorizontalAlignment="Center" />

                    <!-- Info section below radio image -->
                    <StackPanel Margin="12,8,12,12" Spacing="6">

                        <!-- VFO A detail -->
                        <Border Name="VfoACard" Classes="vfoCard" Background="{DynamicResource InfoCardBackground}" CornerRadius="4" Padding="10,6" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1"
                                Cursor="Hand" DoubleTapped="VfoACard_DoubleTapped">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Change Channel..." Click="VfoAChangeChannel_Click" />
                                    <MenuItem Header="Edit Frequency..." Click="VfoAEditFreq_Click" />
                                    <Separator />
                                    <MenuItem Name="VfoAFreqModeItem" Header="Frequency Mode" Click="VfoAFreqMode_Click" IsVisible="False">
                                        <MenuItem.Icon>
                                            <CheckBox Name="VfoAFreqModeCheck" BorderThickness="0" IsHitTestVisible="False" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="A" FontSize="18" FontWeight="Bold" Foreground="#4FC3F7"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Name="VfoAName" Text="--" FontSize="12" Foreground="#4FC3F7" FontWeight="SemiBold" />
                                    <TextBlock Name="VfoAFreq" Text="--- .--- MHz" FontSize="16" Foreground="{DynamicResource PrimaryText}"
                                               FontFamily="Consolas,Liberation Mono,monospace" FontWeight="Bold" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- VFO B detail -->
                        <Border Name="VfoBCard" Classes="vfoCard" Background="{DynamicResource InfoCardBackground}" CornerRadius="4" Padding="10,6" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1"
                                Cursor="Hand" DoubleTapped="VfoBCard_DoubleTapped">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Change Channel..." Click="VfoBChangeChannel_Click" />
                                    <MenuItem Header="Edit Frequency..." Click="VfoBEditFreq_Click" />
                                    <Separator />
                                    <MenuItem Name="VfoBFreqModeItem" Header="Frequency Mode" Click="VfoBFreqMode_Click" IsVisible="False">
                                        <MenuItem.Icon>
                                            <CheckBox Name="VfoBFreqModeCheck" BorderThickness="0" IsHitTestVisible="False" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="B" FontSize="18" FontWeight="Bold" Foreground="#81C784"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Name="VfoBName" Text="--" FontSize="12" Foreground="#81C784" FontWeight="SemiBold" />
                                    <TextBlock Name="VfoBFreq" Text="--- .--- MHz" FontSize="16" Foreground="{DynamicResource PrimaryText}"
                                               FontFamily="Consolas,Liberation Mono,monospace" FontWeight="Bold" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- RSSI and TX bars -->
                        <Border Background="{DynamicResource InfoCardBackground}" CornerRadius="4" Padding="10,6" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
                            <Grid ColumnDefinitions="50,*" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="RSSI" Foreground="{DynamicResource SecondaryText}" FontSize="11" VerticalAlignment="Center" />
                                <ProgressBar Name="RssiBar" Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="16"
                                             Value="0" Height="12" Foreground="#4CAF50" Background="#333" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="TX" Foreground="{DynamicResource SecondaryText}" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,4,0,0" />
                                <Border Name="TxIndicator" Grid.Row="1" Grid.Column="1" Height="12" Margin="0,4,0,0"
                                        Background="#333" CornerRadius="2">
                                    <Border Name="TxIndicatorFill" Background="#333" CornerRadius="2" HorizontalAlignment="Stretch" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Status grid -->
                        <Border Background="{DynamicResource InfoCardBackground}" CornerRadius="4" Padding="10,6" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" Margin="0">
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,2">
                                    <TextBlock Text="Battery" Foreground="{DynamicResource SecondaryText}" FontSize="10" />
                                    <TextBlock Name="BatteryText" Text="--%" Foreground="{DynamicResource PrimaryText}" FontSize="13" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,2">
                                    <TextBlock Text="GPS" Foreground="{DynamicResource SecondaryText}" FontSize="10" />
                                    <TextBlock Name="GpsText" Text="--" Foreground="{DynamicResource PrimaryText}" FontSize="13" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,2">
                                    <TextBlock Text="Squelch" Foreground="{DynamicResource SecondaryText}" FontSize="10" />
                                    <TextBlock Name="SquelchText" Text="--" Foreground="{DynamicResource PrimaryText}" FontSize="13" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,2">
                                    <TextBlock Text="Scan" Foreground="{DynamicResource SecondaryText}" FontSize="10" />
                                    <TextBlock Name="ScanText" Text="--" Foreground="{DynamicResource PrimaryText}" FontSize="13" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,2">
                                    <TextBlock Text="Power" Foreground="{DynamicResource SecondaryText}" FontSize="10" />
                                    <TextBlock Name="PowerText" Text="--" Foreground="{DynamicResource PrimaryText}" FontSize="13" FontWeight="SemiBold" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Channel list -->
                        <TextBlock Text="Channels" FontSize="12" Foreground="{DynamicResource SecondaryText}" FontWeight="SemiBold" Margin="0,4,0,2" />
                        <ListBox Name="ChannelList" DoubleTapped="ChannelList_DoubleTapped"
                                 DragDrop.AllowDrop="True"
                                 Background="Transparent" Padding="0" BorderThickness="0">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Set as VFO A" Click="ChannelSetVfoA_Click" />
                                    <MenuItem Header="Set as VFO B" Click="ChannelSetVfoB_Click" />
                                    <Separator />
                                    <MenuItem Header="Edit Channel..." Click="ChannelEdit_Click" />
                                    <Separator />
                                    <MenuItem Name="ChannelVfoAFreqModeItem" Header="VFO A Frequency Mode" Click="VfoAFreqMode_Click" IsVisible="False">
                                        <MenuItem.Icon>
                                            <CheckBox Name="ChannelVfoAFreqModeCheck" BorderThickness="0" IsHitTestVisible="False" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Name="ChannelVfoBFreqModeItem" Header="VFO B Frequency Mode" Click="VfoBFreqMode_Click" IsVisible="False">
                                        <MenuItem.Icon>
                                            <CheckBox Name="ChannelVfoBFreqModeCheck" BorderThickness="0" IsHitTestVisible="False" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="MinHeight" Value="0" />
                                </Style>
                                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#33FFFFFF" />
                                </Style>
                                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#1AFFFFFF" />
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,1" Padding="6,3" CornerRadius="3"
                                            Background="{Binding Background}">
                                        <Grid ColumnDefinitions="22,*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding Id}" Foreground="{DynamicResource TertiaryText}" FontSize="10" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{Binding NameColor}"
                                                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding Frequency}" Foreground="{DynamicResource SecondaryText}" FontSize="10"
                                                       FontFamily="Consolas,Liberation Mono,monospace" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main tab control -->
        <TabControl Name="MainTabControl" Margin="4">
            <TabItem Header="Communication">
                <tabs:VoiceTabControl />
            </TabItem>
            <TabItem Header="Contacts">
                <tabs:ContactsTabControl />
            </TabItem>
            <TabItem Header="Packets">
                <tabs:PacketCaptureTabControl />
            </TabItem>
            <TabItem Header="Terminal">
                <tabs:TerminalTabControl />
            </TabItem>
            <TabItem Header="BBS">
                <tabs:BbsTabControl />
            </TabItem>
            <TabItem Header="Mail">
                <tabs:MailTabControl />
            </TabItem>
            <TabItem Header="Torrent">
                <tabs:TorrentTabControl />
            </TabItem>
            <TabItem Header="APRS">
                <tabs:AprsTabControl />
            </TabItem>
            <TabItem Header="Map">
                <tabs:MapTabControl />
            </TabItem>
            <TabItem Header="Debug">
                <tabs:DebugTabControl />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
